#!/bin/bash

#PBS -N fs_scan
#PBS -A SCSG0001
#PBS -j oe
#PBS -q casper
#PBS -l walltime=4:00:00
#PBS -l select=1:ncpus=1:mpiprocs=1:ompthreads=1:mem=2G

#----------------------------------------------------------------------------
# Determine the directory containing this script, compatible with bash and zsh
if [ -n "${BASH_SOURCE[0]}" ]; then
  SCRIPT_PATH="${BASH_SOURCE[0]}"
elif [ -n "${ZSH_VERSION}" ]; then
  SCRIPT_PATH="${(%):-%x}"
else
  echo "Unknown shell!"
fi
SCRIPT_DIR=$(realpath $(dirname ${SCRIPT_PATH}))
TOP_DIR=$(git rev-parse --show-toplevel)
#----------------------------------------------------------------------------

sep="#----------------------------------------------------------------------------"

sudo -u csgteam rsync -axv /glade/work/benkirk/repos/hpc-usage-queries/fs_scans/data/*.db /glade/u/apps/opt/hpc-usage-queries/fs_scans/data/
